# ============================================================
#  .env.example  —  template for required environment variables
#  Copy this file to ".env" and fill in real values.
#  The real .env is gitignored and must NEVER be committed.
# ============================================================

# ---- PostgreSQL ----
PG_HOST=
PG_PORT=5432
PG_DATABASE=
PG_USER=
PG_PASSWORD=

# ---- API settings ----
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development

# ---- LLM / integrations ----
GROQ_API_KEY=
# Optional: override the agent models. Defaults shown.
# The fallback is used automatically when the primary model emits a malformed
# tool call (e.g. list/breakup queries that join item_master's quoted columns).
GROQ_AGENT_MODEL=llama-3.3-70b-versatile
GROQ_AGENT_FALLBACK_MODEL=openai/gpt-oss-120b
# Small/cheap model for the single-call SQL fallback. Has its OWN per-model daily
# token budget, so it keeps answering after the big model hits its free-tier cap.
GROQ_SQL_MODEL=llama-3.1-8b-instant
SLACK_TOKEN=

# ---- Email (Microsoft Graph) ----
EMAIL_SENDER=
EMAIL_TOKEN_PATH=
EMAIL_RECIPIENTS=
EMAIL_CC=

# ---- Azure AD app (email_sender.py) ----
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
