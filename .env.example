# ============================================================
#  .env.example  —  template for required environment variables
#  Copy this file to ".env" and fill in real values.
#  The real .env is gitignored and must NEVER be committed.
# ============================================================

# ---- PostgreSQL ----
PG_HOST=
PG_PORT=5432
PG_DATABASE=
PG_USER=
PG_PASSWORD=

# ---- API settings ----
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development

# ---- LLM / integrations ----
GROQ_API_KEY=
SLACK_TOKEN=

# ---- Email (Microsoft Graph) ----
EMAIL_SENDER=
EMAIL_TOKEN_PATH=
EMAIL_RECIPIENTS=
EMAIL_CC=

# ---- Azure AD app (email_sender.py) ----
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
