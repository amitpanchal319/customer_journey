# ==========================================================
#  Customer Journey — .gitignore
#  Python (FastAPI + LangGraph) backend  +  Next.js frontend
# ==========================================================

# =========================
# Secrets & Credentials   (NEVER COMMIT)
# =========================
.env
.env.*
!.env.example
secrets.json
credentials.json
groq_config.json
# Himanshu.json contains a live OAuth access_token
Himanshu.json
*token*.json
*credentials*.json
*secret*.json
service-account*.json
*.pem
*.key

# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
ENV/
.venv/
env.bak/
venv.bak/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage/
.tox/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# =========================
# Logs & runtime output
# =========================
logs/
*.log
uvicorn.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Databases / local data
# =========================
*.db
*.sqlite
*.sqlite3

# Generated data, exports & uploads
uploads/
downloads/
data/
exports/
# keep any intentionally-committed samples
*.csv
!**/sample*.csv

# Agent-generated chart images / artifacts
charts/
*.png.tmp

# =========================
# LangChain / LangGraph
# =========================
.langchain/
langchain.db
langgraph.db
.traces/

# =========================
# AI models / checkpoints
# =========================
models/
checkpoints/
*.pt
*.pth
*.ckpt
*.onnx

# =========================
# Node.js / Next.js (frontend)
# =========================
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
.eslintcache

# Package manager debug logs handled above

# =========================
# Caches / temp
# =========================
.cache/
.temp/
tmp/

# =========================
# IDE / Editor
# =========================
.vscode/
.idea/
*.swp
*.swo
*.bak

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# =========================
# Docker
# =========================
.docker/

# =========================
# Claude Code (local agent state)
# =========================
.claude/
